# ==================== Backend - Spring Boot ====================
SPRING_DATASOURCE_URL=jdbc:sqlserver://localhost:1433;databaseName=ai_major_advisor;encrypt=true;trustServerCertificate=true;integratedSecurity=false
SPRING_DATASOURCE_USERNAME=your_sqlserver_username
SPRING_DATASOURCE_PASSWORD=your_sqlserver_password

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Server
SERVER_PORT=8080

# AI API (bạn có thể chọn Gemini, Claude, OpenAI...)
GEMINI_API_KEY=your_gemini_api_key_here
# CLAUDE_API_KEY=your_claude_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# JWT Authentication (nếu bạn dùng security)
JWT_SECRET=your_very_long_and_random_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=86400000   # 24 hours in milliseconds

# ==================== Frontend - React ====================
# Chỉ dùng những biến có prefix REACT_APP_ (nếu dùng Create React App)
# Hoặc VITE_ nếu dùng Vite
REACT_APP_API_URL=http://localhost:8080/api
# VITE_API_URL=http://localhost:8080/api
